# API Keys for Sovereign Aussie Market Research Agent
# Copy this file to .env and fill in your credentials

# Publisher Rocket / K-lytics API
PUBLISHER_ROCKET_API_KEY=your_publisher_rocket_key_here
KLYTICS_API_KEY=your_klytics_key_here

# Amazon KDP Credentials
KDP_EMAIL=your_kdp_email_here
KDP_PASSWORD=your_kdp_password_here

# Google Trends (no key required for pytrends, but proxy optional)
GOOGLE_TRENDS_PROXY=

# Optional: Hugging Face token for Space deployment
HUGGINGFACE_TOKEN=your_hf_token_here
