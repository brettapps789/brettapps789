# API Keys for Sovereign Aussie Market Research Agent
# Copy this file to .env and fill in your actual keys

# Publisher Rocket / K-lytics API
PUBLISHER_ROCKET_API_KEY=your_publisher_rocket_key_here
KLYTICS_API_KEY=your_klytics_key_here

# Google Trends (no key required for public API, but optionally set region)
GOOGLE_TRENDS_GEO=AU

# Amazon KDP (for keyword research)
KDP_ACCESS_KEY=your_kdp_access_key_here
KDP_SECRET_KEY=your_kdp_secret_key_here

# MCP Server settings
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
